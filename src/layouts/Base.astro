---
import "../styles/global.css";
import { withBase } from "../lib/url";

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Garage Log</title>
    <link rel="icon" href={withBase("/favicon.svg")} />
  </head>
  <body>
    <header class="site-header no-print">
      <div class="container">
        <h1><a href={withBase("/")} style="color: inherit; text-decoration: none;">🚗 Garage Log</a></h1>
        <nav>
          <a href={withBase("/")}>Dashboard</a>
          <a href={withBase("/archive")}>Archive</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
