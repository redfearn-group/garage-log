---
import Base from "../layouts/Base.astro";
import { getArchivedVehicles, currentMileage, vehicleLabel } from "../lib/data";
import { withBase } from "../lib/url";

const vehicles = getArchivedVehicles();
---
<Base title="Archive">
  <p><a href={withBase("/")}>← Dashboard</a></p>
  <h2>Archived vehicles</h2>
  <p class="muted">Sold or retired vehicles — full history is kept for reference, just off the main dashboard.</p>

  {vehicles.length === 0 && <p class="muted">Nothing archived yet.</p>}

  <ul class="pill-list">
    {vehicles.map((v) => (
      <li class="card">
        <a href={withBase(`/vehicles/${v.slug}`)}>{vehicleLabel(v)}</a>
        <span class="muted"> — last known mileage: {currentMileage(v)?.toLocaleString() ?? "—"}</span>
      </li>
    ))}
  </ul>
</Base>
