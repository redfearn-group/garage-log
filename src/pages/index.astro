---
import Base from "../layouts/Base.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { getActiveVehicles, currentMileage, vehicleLabel, vehicleShortLabel } from "../lib/data";
import { scheduleStatusesFor, worstStatus, upcomingAdminDates, splitScheduleItemName } from "../lib/status";
import { withBase } from "../lib/url";

const vehicles = getActiveVehicles();

const rows = vehicles.map((vehicle) => {
  const statuses = scheduleStatusesFor(vehicle);
  const dueItems = statuses.filter((s) => s.status === "overdue" || s.status === "due-soon");
  const admin = upcomingAdminDates(vehicle).filter((d) => d.daysUntil <= 60);
  return {
    vehicle,
    mileage: currentMileage(vehicle),
    overall: worstStatus(statuses),
    dueItems,
    admin,
    openTasks: vehicle.tasks.filter((t) => t.status === "open"),
    recallCount: vehicle.openRecalls.length,
  };
});

// Fleet-wide aggregate for the summary strip.
const vehiclesNeedAttentionCount = rows.filter((r) => r.overall !== "ok").length;

// Critical items: Brady's own hand-set task.priority is a more trustworthy
// urgency signal than raw recall counts, which mix decades-old resolved
// recalls with genuinely open ones.
const criticalItems = rows.flatMap((r) =>
  r.openTasks
    .filter((t) => t.priority === "critical")
    .map((t) => ({ vehicle: r.vehicle, task: t }))
);

const accentFor: Record<string, string> = {
  overdue: "var(--rg-red)",
  "due-soon": "var(--rg-tawny)",
  ok: "var(--rg-green)",
  "never-done": "var(--rg-ash)",
};

const tagClassFor: Record<string, string> = {
  overdue: "tag-red",
  "due-soon": "tag-tawny",
  ok: "tag-green",
  "never-done": "tag-neutral",
};

// Small hardcoded body-type lookup — 5 vehicles, not worth a schema change.
const vehicleTypeFor: Record<string, "sedan" | "suv" | "truck"> = {
  "F-150": "truck",
  "ES 300h": "sedan",
  Highlander: "suv",
  Tucson: "suv",
  Impreza: "sedan",
};

const ICONS: Record<"sedan" | "suv" | "truck", string> = {
  sedan:
    "M1 11 L1 8.5 C1 7.7 1.6 7 2.5 7 L5.5 7 L7.5 3.2 C7.9 2.4 8.7 2 9.5 2 L14.5 2 C15.3 2 16.1 2.4 16.5 3.2 L18.5 7 L21.5 7 C22.4 7 23 7.7 23 8.5 L23 11",
  suv:
    "M1 11 L1 7.5 C1 6.7 1.6 6 2.5 6 L4.5 6 L6 2.8 C6.3 2.3 6.9 2 7.5 2 L16.5 2 C17.1 2 17.7 2.3 18 2.8 L19.5 6 L21.5 6 C22.4 6 23 6.7 23 7.5 L23 11",
  truck:
    "M1 11 L1 7.5 C1 6.7 1.6 6 2.5 6 L4 6 L5.5 2.8 C5.8 2.3 6.4 2 7 2 L10.5 2 C11.3 2 12 2.7 12 3.5 L12 6 L20.5 6 C21.9 6 23 7.1 23 8.5 L23 11 M12 6 L12 8.5 L20.5 8.5",
};
---
<Base title="Dashboard">
  <h2>Your vehicles</h2>
  {rows.length === 0 && <p class="muted">No active vehicles yet. Add one to <code>data/vehicles.yaml</code>.</p>}

  {rows.length > 0 && (
    <div class="fleet-stats fleet-stats-single">
      <div class="fleet-stat">
        <div class={`fleet-stat-value ${vehiclesNeedAttentionCount > 0 ? "is-critical" : "is-positive"}`}>
          {vehiclesNeedAttentionCount} / {rows.length}
        </div>
        <div class="fleet-stat-label">Need attention</div>
      </div>
    </div>
  )}

  {criticalItems.length > 0 && (
    <div class="callout callout-alert">
      <p class="callout-label">Alert — {criticalItems.length} critical item{criticalItems.length === 1 ? "" : "s"}</p>
      <div class="callout-body">
        {criticalItems.slice(0, 3).map(({ vehicle, task }) => (
          <span class="callout-item">
            <a href={withBase(`/vehicles/${vehicle.slug}`)}>{vehicleShortLabel(vehicle)}</a>
            {" — "}
            {task.title}
          </span>
        ))}
        {criticalItems.length > 3 && (
          <span class="callout-item muted">+{criticalItems.length - 3} more</span>
        )}
      </div>
    </div>
  )}

  <div class="vehicle-grid">
    {rows.map(({ vehicle, mileage, overall, dueItems, openTasks, recallCount }) => {
      const iconType = vehicleTypeFor[vehicle.model] ?? "sedan";
      const shown = dueItems.slice(0, 3);
      const overflow = dueItems.length - shown.length;
      return (
        <div class="vehicle-card" style={`--card-accent: ${accentFor[overall]}`}>
          <div class="vehicle-card-header">
            <div class="vehicle-card-title">
              <svg class="vehicle-type-icon" viewBox="0 0 24 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={ICONS[iconType]} />
                <circle cx="6" cy="11" r="2" />
                <circle cx={iconType === "truck" ? "18.5" : "18"} cy="11" r="2" />
              </svg>
              <h3><a href={withBase(`/vehicles/${vehicle.slug}`)}>{vehicleLabel(vehicle)}</a></h3>
            </div>
            <StatusBadge status={overall} />
          </div>

          <div class="stat-row">
            <div>
              <div class="stat-value">{mileage != null ? mileage.toLocaleString() : "—"}</div>
              <div class="stat-label">Miles</div>
            </div>
            <div>
              <div class="stat-value">{openTasks.length}</div>
              <div class="stat-label">Open task{openTasks.length === 1 ? "" : "s"}</div>
            </div>
            {recallCount > 0 && (
              <div>
                <div class="stat-value">{recallCount}</div>
                <div class="stat-label">Open recall{recallCount === 1 ? "" : "s"}</div>
              </div>
            )}
          </div>

          {dueItems.length > 0 && (
            <div class="card-section">
              <p class="section-label">Needs attention</p>
              <div class="tag-row">
                {shown.map((s) => (
                  <span class={`tag ${tagClassFor[s.status]}`}>{splitScheduleItemName(s.item.name).short}</span>
                ))}
                {overflow > 0 && (
                  <a class="tag tag-neutral tag-link" href={withBase(`/vehicles/${vehicle.slug}`)}>
                    +{overflow} more →
                  </a>
                )}
              </div>
            </div>
          )}

          <a class="card-link" href={withBase(`/vehicles/${vehicle.slug}`)}>View full history →</a>
        </div>
      );
    })}
  </div>
</Base>
