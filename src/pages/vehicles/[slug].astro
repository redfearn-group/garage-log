---
import Base from "../../layouts/Base.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { getVehicleSummaries, getVehicle, currentMileage, vehicleLabel } from "../../lib/data";
import { scheduleStatusesFor, upcomingAdminDates, splitScheduleItemName, currentMileageAtOrAbove } from "../../lib/status";
import { withBase } from "../../lib/url";
import { formatDate } from "../../lib/date";

export function getStaticPaths() {
  return getVehicleSummaries().map((v) => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const vehicle = getVehicle(slug!);
const statuses = scheduleStatusesFor(vehicle);
const mileage = currentMileage(vehicle);
const adminDates = upcomingAdminDates(vehicle);
const sortedMileageLog = [...vehicle.mileageLog].sort((a, b) => (a.date < b.date ? 1 : -1));
const sortedMaintenanceLog = [...vehicle.maintenanceLog].sort((a, b) => (a.date < b.date ? 1 : -1));
const openTasks = vehicle.tasks.filter((t) => t.status === "open");
const doneTasks = vehicle.tasks.filter((t) => t.status === "done");
// Addressed items are already in maintenance-log.yaml — the watch list is
// only for things still worth watching for.
const activeWatchList = vehicle.watchList.filter((w) => w.status !== "addressed");

// simple inline sparkline points for the mileage trend
const points = [...vehicle.mileageLog].sort((a, b) => (a.date < b.date ? -1 : 1));
const chartW = 600, padX = 10, padTop = 10, padBottom = 22, plotH = 90;
const chartH = padTop + plotH + padBottom;
let polyline = "";
let yearMarkers: { x: number; year: number }[] = [];
if (points.length > 1) {
  const minM = Math.min(...points.map((p) => p.mileage));
  const maxM = Math.max(...points.map((p) => p.mileage));
  // Anchor the timeline at the purchase date (not the first odometer
  // reading) so any gap before the first logged mileage still shows up.
  const minT = vehicle.purchaseDate
    ? new Date(vehicle.purchaseDate).getTime()
    : new Date(points[0].date).getTime();
  const maxT = new Date(points[points.length - 1].date).getTime();
  const range = maxM - minM || 1;
  const trange = maxT - minT || 1;
  const xFor = (t: number) => padX + ((t - minT) / trange) * (chartW - padX * 2);
  polyline = points
    .map((p) => {
      const x = xFor(new Date(p.date).getTime());
      const y = padTop + plotH - ((p.mileage - minM) / range) * plotH;
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(" ");
  const startYear = new Date(minT).getFullYear();
  const endYear = new Date(maxT).getFullYear();
  for (let year = startYear; year <= endYear; year++) {
    const t = new Date(`${year}-01-01`).getTime();
    if (t < minT || t > maxT) continue;
    yearMarkers.push({ x: xFor(t), year });
  }
}
---
<Base title={vehicleLabel(vehicle)}>
  <p class="no-print"><a href={withBase("/")}>← Dashboard</a></p>
  <div style="display:flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem;">
    <h2 style="margin: 0;">{vehicleLabel(vehicle)}</h2>
    <a class="no-print" href={withBase(`/vehicles/${vehicle.slug}/export`)}>Printable / export history →</a>
  </div>
  <p class="muted" style="margin-top: 0.25rem;">
    VIN: {vehicle.vin || "<private>"} · Plate: {vehicle.licensePlate || "<private>"} · Tires: {vehicle.tireSize || "—"} · Purchased: {vehicle.purchaseDate ? formatDate(vehicle.purchaseDate) : "—"}
  </p>
  {vehicle.previousOwner && <p class="muted">{vehicle.previousOwner}</p>}

  <div class="stat-row card">
    <div class="stat"><strong>{mileage != null ? mileage.toLocaleString() : "—"}</strong>current miles</div>
    <div class="stat"><strong>{sortedMaintenanceLog.length}</strong>logged services</div>
    <div class="stat"><strong>{openTasks.length}</strong>open tasks</div>
    <div class="stat"><strong>{vehicle.documents.length}</strong>documents</div>
  </div>

  <details class="section" open>
    <summary class="section-summary">Maintenance schedule</summary>
    <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Item</th><th>Status</th><th>Last done</th><th>Due at</th></tr>
      </thead>
      <tbody>
        {statuses.map((s) => {
          const { short, citation } = splitScheduleItemName(s.item.name);
          return (
          <tr>
            <td>
              {citation ? (
                <details>
                  <summary>{short}</summary>
                  <p class="muted" style="font-size:0.85rem; margin: 0.35rem 0 0;">{citation}</p>
                </details>
              ) : short}
            </td>
            <td><StatusBadge status={s.status} /></td>
            <td>{s.lastDone ? (s.lastDone.mileage != null ? `${formatDate(s.lastDone.date)} (${s.lastDone.mileage.toLocaleString()} mi)` : formatDate(s.lastDone.date)) : "—"}</td>
            <td>
              {s.dueMileage != null ? `${s.dueMileage.toLocaleString()} mi` : ""}
              {s.dueMileage != null && s.dueDate != null ? " / " : ""}
              {s.dueDate != null ? formatDate(s.dueDate) : ""}
              {s.dueMileage == null && s.dueDate == null ? "—" : ""}
            </td>
          </tr>
          );
        })}
      </tbody>
    </table>
    </div>
  </details>

  {activeWatchList.length > 0 && (
    <details class="section" open>
      <summary class="section-summary">Things to watch for</summary>
      <div class="table-wrap">
      <table>
        <thead><tr><th>Issue</th><th>Typical mileage</th><th>Status</th></tr></thead>
        <tbody>
          {activeWatchList.map((w) => {
            const mileageReached = w.status === "not-yet-at-mileage" && currentMileageAtOrAbove(mileage, w.typicalMileage);
            return (
            <tr>
              <td>{w.issue}<div class="muted" style="font-size:0.85rem;">{w.description}</div></td>
              <td>{w.typicalMileage ? w.typicalMileage.toLocaleString() + " mi" : "—"}</td>
              <td>
                {w.status}
                {mileageReached && <span class="tag tag-tawny" style="margin-left: 0.4rem;">Mileage reached</span>}
              </td>
            </tr>
            );
          })}
        </tbody>
      </table>
      </div>
    </details>
  )}

  <details class="section" open>
    <summary class="section-summary">Tasks</summary>
    <ul class="pill-list">
      {openTasks.map((t) => (
        <li>
          ☐ {t.priority === "critical" && <span class="tag tag-red" style="margin-right: 0.4rem;">Critical</span>}
          {t.title} <span class="muted">({formatDate(t.createdDate)})</span>
        </li>
      ))}
      {doneTasks.map((t) => <li class="muted">☑ {t.title}</li>)}
      {vehicle.tasks.length === 0 && <li class="muted">No tasks.</li>}
    </ul>
  </details>

  {vehicle.openRecalls.length > 0 && (
    <details class="section" open>
      <summary class="section-summary">Open recalls (NHTSA)</summary>
      <p class="muted" style="font-size:0.85rem;">
        Last checked: {vehicle.recallsData.lastChecked ? formatDate(vehicle.recallsData.lastChecked) : "never"}
      </p>
      {vehicle.openRecalls.map((r) => (
        <div class="card" style="border-color: var(--status-overdue-fg);">
          <strong>{r.component}</strong>
          <p style="margin: 0.25rem 0 0;">{r.summary}</p>
        </div>
      ))}
    </details>
  )}

  {points.length > 1 && (
    <details class="section">
      <summary class="section-summary">Mileage trend</summary>
      <svg viewBox={`0 0 ${chartW} ${chartH}`} width="100%" height={chartH} role="img">
        {yearMarkers.map((m) => (
          <>
            <line x1={m.x} y1={padTop} x2={m.x} y2={padTop + plotH} stroke="var(--border)" stroke-width="1" stroke-dasharray="2,2" />
            <text x={m.x} y={chartH - 6} text-anchor="middle" font-size="9" fill="var(--text-muted)">{m.year}</text>
          </>
        ))}
        <polyline points={polyline} fill="none" stroke="var(--accent)" stroke-width="2" />
      </svg>
    </details>
  )}

  <details class="section">
    <summary class="section-summary">Mileage log</summary>
    <div class="table-wrap">
    <table>
      <thead><tr><th>Date</th><th>Mileage</th></tr></thead>
      <tbody>
        {sortedMileageLog.map((m) => <tr><td>{formatDate(m.date)}</td><td>{m.mileage.toLocaleString()}</td></tr>)}
      </tbody>
    </table>
    </div>
  </details>

  <details class="section">
    <summary class="section-summary">Maintenance history</summary>
    <div class="table-wrap">
    <table>
      <thead><tr><th>Date</th><th>Mileage</th><th>Item</th><th>Notes</th></tr></thead>
      <tbody>
        {sortedMaintenanceLog.map((m) => (
          <tr>
            <td>{formatDate(m.date)}</td>
            <td>{m.mileage != null ? m.mileage.toLocaleString() : "—"}</td>
            <td>{m.description}</td>
            <td class="muted">{m.notes}</td>
          </tr>
        ))}
      </tbody>
    </table>
    </div>
  </details>

  <details class="section">
    <summary class="section-summary">Admin dates</summary>
    <div class="table-wrap">
    <table>
      <thead><tr><th>Type</th><th>Due</th><th>Notes</th></tr></thead>
      <tbody>
        {adminDates.map((d) => <tr><td>{d.label}</td><td>{formatDate(d.dueDate)}</td><td class="muted">{d.notes}</td></tr>)}
        {adminDates.length === 0 && <tr><td colspan="3" class="muted">None on file.</td></tr>}
      </tbody>
    </table>
    </div>
  </details>

  <details class="section">
    <summary class="section-summary">Documents</summary>
    <p class="muted" style="font-size:0.85rem;">🔒 Source files are kept in a private repo — only the summary below is public.</p>
    <ul class="pill-list">
      {vehicle.documents.map((doc) => (
        <li>
          <span>{doc.filename}</span>
          <span class="muted"> — {doc.category}, added {formatDate(doc.dateAdded)}</span>
          {doc.description && <div class="muted" style="font-size:0.85rem;">{doc.description}</div>}
        </li>
      ))}
      {vehicle.documents.length === 0 && <li class="muted">No documents uploaded.</li>}
    </ul>
  </details>
</Base>
